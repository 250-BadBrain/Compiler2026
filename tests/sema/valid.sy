const int N = 2 + 3;
int g[N] = {1, 2, 3};

int sum(int a[], int n) {
    int i = 0;
    int s = 0;
    while (i < n) {
        s = s + a[i];
        i = i + 1;
    }
    return s;
}

float addf(float x, int y) {
    return x + y;
}

int main() {
    int local[N] = {};
    local[0] = getint();
    putint(sum(local, N));
    putf("%d\n", local[0]);
    return 0;
}
